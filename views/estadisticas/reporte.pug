extends ../layout

block content
  .card.col-12
    .card-header
      h1 Reporte Estadístico Hot Sale
      a.btn.btn-ghost(href="/") Volver al Panel
    
    .card-body(style="padding: 20px;")
      ul(style="list-style: none; font-size: 18px; line-height: 2;")
        li 
          strong Evento: 
          | #{reporte.evento}
        li 
          strong Ventas Totales: 
          | #{reporte.ventasTotales} operaciones
        li 
          strong Volumen Movido: 
          | $#{reporte.volumenMovido}
        li 
          strong Ganancia Plataforma: 
          | $#{reporte.gananciaPlataforma}
        li 
          strong Tasa de Error: 
          | #{reporte.tasaError}
        li 
          strong Estado del Sistema: 
          | #{reporte.estadoSistema}