extends layout

block content
  .grid
    //- Encabezado principal del Panel
    .card.col-12
      .card-header
        div
          h1 Panel principal
          p.muted Administración de módulos y operaciones del sistema.

    //- 1. Módulo Comercios
    .card.col-6
      .card-header
        div
          h2 Comercios
          p.muted Gestión de comercios adheridos a la plataforma.
      .actions
        a.btn.btn-primary(href="/comercios/vista") Ver listado
        a.btn.btn-ghost(href="/comercios/nuevo") Registrar nuevo

    //- 2. Módulo Tiendas
    .card.col-6
      .card-header
        div
          h2 Tiendas
          p.muted Gestión de sucursales virtuales por comercio.
      .actions
        a.btn.btn-primary(href="/tiendas/vista") Ver listado
        a.btn.btn-ghost(href="/tiendas/nuevo") Registrar nueva

    //- 3. Módulo Transacciones
    .card.col-6
      .card-header
        div
          h2 Transacciones
          p.muted Procesamiento de ventas y cálculo de comisiones.
      .actions
        a.btn.btn-primary(href="/transacciones/vista") Ver listado
        a.btn.btn-ghost(href="/transacciones/nuevo") Procesar venta

    //- 4. Módulo Logística
    .card.col-6
      .card-header
        div
          h2 Logística
          p.muted Gestión de envíos validados contra transacciones.
      .actions
        a.btn.btn-primary(href="/logistica/vista") Ver listado
        a.btn.btn-ghost(href="/logistica/nuevo") Crear envío

    //- 5. Módulo Usuarios
    .card.col-6
      .card-header
        div
          h2 Usuarios
          p.muted Administración del personal interno del sistema.
      .actions
        a.btn.btn-primary(href="/usuarios/vista") Ver listado
        a.btn.btn-ghost(href="/usuarios/nuevo") Registrar nuevo

    //- 6. Módulo Estadísticas
    .card.col-6
      .card-header
        div
          h2 Reporte Hot Sale
          p.muted Métricas financieras y estado de la pasarela.
      .actions
        a.btn.btn-primary(href="/estadisticas/vista") Ver Reporte