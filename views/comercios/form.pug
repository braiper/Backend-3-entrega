extends ../layout

block content
  .card
    .card-header
      div
        h2 Nuevo Comercio
        p.muted Completá los datos para registrar un comercio en la plataforma.
      .actions
        a.btn(href="/comercios/vista") Volver al listado
        a.btn.btn-ghost(href="/") Inicio

    form(method="POST", action="/comercios/vista")
      .form-grid
        .field.field-full
          label(for="nombre_comercio") Nombre del comercio
          input#nombre_comercio(type="text", name="nombre_comercio", placeholder="Ej: Mascotas SRL", required)

        .field
          label(for="cuit") CUIT
          input#cuit(type="text", name="cuit", placeholder="Ej: 20-12345678-9", minlength="11", maxlength="13", pattern="\\d{2}-\\d{8}-\\d{1}", required)

        .field
          label(for="email_contacto") Email de contacto
          input#email_contacto(type="email", name="email_contacto", placeholder="contacto@empresa.com", required)

        .field
          label(for="plan_suscripcion") Plan de suscripción
          select#plan_suscripcion(name="plan_suscripcion")
            option(value="Basico") Básico
            option(value="Premium") Premium

        .field
          label(for="comision_variable") Comisión variable
          input#comision_variable(type="number", step="0.01", min="0", max="1", name="comision_variable", placeholder="Ingrese valores entre 0 y 1")

      .actions
        button.btn.btn-primary(type="submit") Guardar
