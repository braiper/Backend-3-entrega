extends ../layout

block content
  .card-header
    h1 Panel de Alertas e Interoperabilidad
    p.muted Monitoreo de tickets, pasarelas de pago y salud financiera.

  // DASHBOARD DE MÉTRICAS
  .grid(style="margin-bottom: 24px;")
    .col-6(style="grid-column: span 4;")
      .card(style="border-left: 4px solid var(--primary);")
        h3(style="color: var(--muted); font-size: 13px; text-transform: uppercase;") Alertas Pendientes
        p(style="font-size: 28px; font-weight: 800; margin: 0; color: #ef4444;") #{pendientes}
    .col-6(style="grid-column: span 4;")
      .card(style="border-left: 4px solid #10b981;")
        h3(style="color: var(--muted); font-size: 13px; text-transform: uppercase;") Alertas Resueltas
        p(style="font-size: 28px; font-weight: 800; margin: 0; color: #10b981;") #{resueltas}
    .col-6(style="grid-column: span 4;")
      .card(style="border-left: 4px solid #f59e0b;")
        h3(style="color: var(--muted); font-size: 13px; text-transform: uppercase;") Discrepancias Financieras
        p(style="font-size: 28px; font-weight: 800; margin: 0; color: #f59e0b;") #{financieras}

  // LISTADO DE TICKETS/ALERTAS
  .card
    if alertas.length === 0
      p(style="text-align: center; padding: 30px; color: var(--muted);") No hay alertas en el sistema. ¡Todo funciona correctamente! 🎉
    else
      table
        thead
          tr
            th Estado
            th Tipo
            th Mensaje
            th Prioridad
            th Fecha
            th Acciones
        tbody
          each alerta in alertas
            tr
              td
                if alerta.estado === 'Pendiente'
                  span.badge.badge-danger Pendiente
                else
                  span.badge.badge-success Resuelta
              td
                strong #{alerta.tipo}
              td #{alerta.mensaje}
              td
                if alerta.prioridad === 'Alta'
                  span.badge(style="background: #fee2e2; color: #b91c1c;") Alta
                else if alerta.prioridad === 'Media'
                  span.badge(style="background: #fef3c7; color: #b45309;") Media
                else
                  span.badge(style="background: #f3f4f6; color: #374151;") Baja
              td #{new Date(alerta.fecha).toLocaleString()}
              td
                if alerta.estado === 'Pendiente'
                  form(action=`/alertas/vista/${alerta._id}/resolver` method="POST" style="display:inline;")
                    button.btn.btn-ghost(type="submit" style="padding: 4px 10px; font-size: 12px; color: #10b981; border-color: rgba(16,185,129,0.2);") ✔ Resolver
