extends ../layout

block content
  .card.col-12
    .card-header
      div
        h1 Sucursales (Tiendas)
        p.muted Listado de tiendas virtuales registradas en TechRetail.
      .actions
        a.btn.btn-ghost(href="/") Volver al Panel

    table
      thead
        tr
          th ID
          th Nombre de Sucursal
          th Comercio
          th Ubicación
          th Estado
      tbody
        each tienda in tiendas
          tr
            td= tienda._id
            td= tienda.nombre_sucursal
            td= tienda.comercio_id.nombre_comercio
            td= tienda.ubicacion
            td
              if tienda.estado === "Activo" || tienda.estado === "Activa"
                span.status-dot.status-dot--active(title=tienda.estado)
              else
                span.status-dot.status-dot--inactive(title=tienda.estado)
        else
          tr
            td(colspan="5") No hay tiendas registradas en este momento.
