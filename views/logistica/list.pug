extends ../layout

block content
  .card.col-12
    .card-header
      h1 Envíos Logísticos
      a.btn.btn-ghost(href="/") Volver al Panel
    table
      thead
        tr
          th ID
          th Transacción ID
          th Empresa Transporte
          th Destino
          th Estado
      tbody
        //- Cambiamos "logistica" por "envios"
        each envio in envios
          tr
            td= envio._id
            //- Cambiamos "id_transaccion" por "transaccion_id"
            td= envio.transaccion_id
            td= envio.empresa_transporte
            td= envio.direccion_destino
            //- Agregamos la columna de estado
            td= envio.estado_envio